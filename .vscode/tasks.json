{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/software/project/scripts/build.sh", "devkit"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "bash",
      "args": ["${workspaceFolder}/software/project/scripts/clean.sh", "devkit"],
      "group": "build",
      "presentation": { "reveal": "silent", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Flash",
      "type": "shell",
      "command": "openocd",
      "args": [
        "-f", "interface/stlink.cfg",
        "-f", "target/stm32f4x.cfg",
        "-c", "program ${workspaceFolder}/software/project/build/devkit/gambos.elf verify reset exit"
      ],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Build and Flash",
      "dependsOrder": "sequence",
      "dependsOn": ["Build", "Flash"],
      "group": "build",
      "problemMatcher": []
    }
  ]
}
