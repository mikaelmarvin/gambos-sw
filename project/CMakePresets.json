{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {}
        },
        {
            "name": "custom",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BOARD": "custom"
            }
        },
        {
            "name": "devkit",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BOARD": "devkit"
            }
        },
        {
            "name": "bluepill",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BOARD": "bluepill"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "custom",
            "configurePreset": "custom"
        },
        {
            "name": "devkit",
            "configurePreset": "devkit"
        },
        {
            "name": "bluepill",
            "configurePreset": "bluepill"
        }
    ]
}